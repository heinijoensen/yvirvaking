# Yvirvaking — Environment Variables
# Copy this file to .env.local for local development with `vercel dev`
# Set these in the Vercel dashboard for production: Settings → Environment Variables

# MyUplink OAuth credentials
# Get these from dev.myuplink.com → your app → Details
# ⚠️  Rotate the secret before deploying — it was previously in config.js
MYUPLINK_CLIENT_ID=your-client-id-here
MYUPLINK_CLIENT_SECRET=your-new-rotated-secret-here
